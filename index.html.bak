};

function useTypewriter(speed=10){
  const [display,setDisplay]=useState('');
  const [running,setRunning]=useState(false);
  const ref=useRef(null);
  const startTyping=useCallback((text)=>{
    setDisplay('');setRunning(true);
    let i=0;
    if(ref.current)clearInterval(ref.current);
    ref.current=setInterval(()=>{
      i++;setDisplay(text.slice(0,i));
      if(i>=text.length){clearInterval(ref.current);setRunning(false);}
    },speed);
  },[speed]);
  useEffect(()=>()=>{if(ref.current)clearInterval(ref.current);},[]);
  return{display,running,startTyping};
}

function NavBar({page,goTo,adminMode,setAdminMode}){
  const links=[['home','Home'],['memberships','Memberships'],['coaching','Coaching'],['classes','Classes'],['transformations','Results'],['stories','Stories'],['about','About'],['faq','FAQ']];
  if(adminMode)return(
    <nav style={{background:'#08080C',borderBottom:`1px solid ${C.border}`,padding:'0 24px',height:56,display:'flex',alignItems:'center',justifyContent:'space-between',position:'sticky',top:0,zIndex:100}}>
      <div style={{display:'flex',alignItems:'center',gap:10}}>
        <span style={{...bdg(C.red),fontSize:10}}>OPERATOR SUITE</span>
        <span style={{fontWeight:700,fontSize:14}}>Iron Tribe Admin</span>
      </div>
      <button style={{...btn(C.red,true),fontSize:13,padding:'7px 14px'}} onClick={()=>setAdminMode(false)}>Exit Admin</button>
    </nav>
  );
  return(
    <nav style={{background:C.card,borderBottom:`1px solid ${C.border}`,padding:'0 20px',height:56,display:'flex',alignItems:'center',justifyContent:'space-between',position:'sticky',top:0,zIndex:100}}>
      <div style={{display:'flex',alignItems:'center',gap:6,cursor:'pointer'}} onClick={()=>goTo('home')}>
        <span style={{...DISPLAY,color:C.red,fontWeight:800,fontSize:18}}>IRON TRIBE</span>
        <span style={{color:C.text3,fontSize:11,marginLeft:4}}>FITNESS GYM</span>
      </div>
      <div style={{display:'flex',gap:2}}>
        {links.map(([p,l])=>(
          <span key={p} onClick={()=>goTo(p)} style={{cursor:'pointer',fontSize:13,color:page===p?C.text:C.text2,background:page===p?C.hover:'transparent',padding:'6px 10px',borderRadius:6,userSelect:'none'}}>{l}</span>
        ))}
      </div>
      <div style={{display:'flex',gap:8}}>
        <button style={{...btn(),fontSize:13,padding:'8px 14px'}} onClick={()=>goTo('join')}>Book Assessment</button>
        <button style={{...btn(C.red,true),fontSize:12,padding:'7px 12px'}} onClick={()=>setAdminMode(true)}>Operator</button>
      </div>
    </nav>
  );
}

function HomePage({goTo}){
  return(
    <div>
      <div style={{...sec,paddingTop:72,paddingBottom:64}}>
        <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:56,alignItems:'center'}}>
          <div>
            <span style={lbl}>Malvar, Batangas · Est. 2023</span>
            <h1 style={{...DISPLAY,fontSize:64,fontWeight:800,lineHeight:1.0,margin:'10px 0 20px'}}>The Fitness Home<br/><span style={{color:C.red}}>for Malvar.</span></h1>
            <p style={{color:C.text2,fontSize:15,lineHeight:1.7,marginBottom:28}}>Iron Tribe is a coaching-led training environment. Every member gets a dedicated coach, a structured program, and a community that keeps you accountable.</p>
            <div style={{display:'flex',gap:10,marginBottom:14}}>
              <button style={{...btn(),padding:'13px 26px',fontSize:14}} onClick={()=>goTo('join')}>Book Free Assessment</button>
              <button style={{...btn(C.red,true),padding:'13px 26px',fontSize:14}} onClick={()=>goTo('memberships')}>View Plans</button>
            </div>
            <div style={{fontSize:12,color:C.text3}}>4F Noli Rose Bldg, 474 J.P. Laurel Hwy, Malvar · Open 8AM–10PM Daily</div>
          </div>
          <div style={{position:'relative'}}>
            <img src={PHOTOS.gymWide} alt="Iron Tribe Fitness Gym — Malvar, Batangas" style={{width:'100%',height:420,objectFit:'cover',borderRadius:16,display:'block'}}/>
            <div style={{position:'absolute',bottom:16,left:16,background:'rgba(7,7,9,0.75)',backdropFilter:'blur(8px)',borderRadius:8,padding:'8px 14px',fontSize:11,color:C.text2,letterSpacing:'0.05em'}}>Iron Tribe · Malvar, Batangas</div>
          </div>
        </div>
      </div>
      <div style={{background:C.card,borderTop:`1px solid ${C.border}`,borderBottom:`1px solid ${C.border}`}}>
        <div style={{maxWidth:1100,margin:'0 auto',padding:'22px 28px',display:'grid',gridTemplateColumns:'repeat(4,1fr)',gap:24}}>
          {[['67+','Active Members'],['4','Expert Coaches'],['8','Weekly Classes'],['94%','Retention Rate']].map(([v,l])=>(
            <div key={l} style={{textAlign:'center'}}>
              <div style={{...DISPLAY,fontSize:32,color:C.red}}>{v}</div>
              <div style={{fontSize:12,color:C.text2}}>{l}</div>
            </div>
          ))}
        </div>
      </div>
      <div style={sec}>
        <span style={lbl}>What We Offer</span>
        <h2 style={h1s}>Training Programs</h2>
        <div style={{display:'grid',gridTemplateColumns:'repeat(2,1fr)',gap:14}}>
          {[['Strength & Conditioning','Barbell-based programming for real, measurable strength gains.','coaching'],
            ['Nutrition & Body Comp','Evidence-based nutrition coaching paired with smart training.','coaching'],
            ['Calisthenics & Skills','From first pull-up to advanced skills — progressive bodyweight mastery.','coaching'],
            ['Group HIIT Classes',"High-energy group sessions — Coach Rica's HIIT consistently sells out.",'classes'],
          ].map(([title,desc,target])=>(
            <div key={title} style={{...card,cursor:'pointer'}} onClick={()=>goTo(target)}>
              <div style={{fontWeight:700,fontSize:15,marginBottom:6}}>{title}</div>
              <div style={{fontSize:13,color:C.text2,lineHeight:1.6,marginBottom:12}}>{desc}</div>
              <span style={{color:C.red,fontSize:13,fontWeight:600}}>Explore</span>
            </div>
          ))}
        </div>
      </div>
      <div style={{padding:'0 28px 56px'}}>
        <div style={{maxWidth:1100,margin:'0 auto',display:'grid',gridTemplateColumns:'2fr 1fr 1fr',gap:8,borderRadius:16,overflow:'hidden'}}>
          <img src={PHOTOS.gymFloor} alt="Iron Tribe gym floor" style={{width:'100%',height:320,objectFit:'cover',display:'block'}}/>
          <img src={PHOTOS.portrait1} alt="Iron Tribe training" style={{width:'100%',height:320,objectFit:'cover',display:'block'}}/>
          <img src={PHOTOS.gymWide} alt="Iron Tribe fitness floor" style={{width:'100%',height:320,objectFit:'cover',display:'block'}}/>
        </div>
      </div>
      <div style={{background:C.card,borderTop:`1px solid ${C.border}`,padding:'56px 28px'}}>
        <div style={{maxWidth:1100,margin:'0 auto'}}>
          <span style={lbl}>Simple Pricing</span>
          <h2 style={h1s}>Membership Plans</h2>
          <div style={{display:'grid',gridTemplateColumns:'repeat(3,1fr)',gap:14}}>
            {[{name:'Student Monthly',price:'799',per:'/mo',color:C.border,tag:''},
              {name:'Regular Monthly',price:'999',per:'/mo',color:C.red,tag:'Most Popular'},
              {name:'Annual Plan',price:'8,000',per:'/yr',color:C.gold,tag:'Best Value'},
            ].map(p=>(
              <div key={p.name} style={{...card,border:`2px solid ${p.color}`,position:'relative'}}>
                {p.tag&&<div style={{...bdg(p.color===C.border?C.text2:p.color),position:'absolute',top:-10,left:16,fontSize:10}}>{p.tag}</div>}
                <div style={{fontSize:13,color:C.text2,marginBottom:4}}>{p.name}</div>
                <div style={{fontSize:30,fontWeight:800}}>₱{p.price}<span style={{fontSize:13,fontWeight:400,color:C.text2}}>{p.per}</span></div>
                <button style={{...btn(p.color===C.border?C.red:p.color),width:'100%',marginTop:14,fontSize:13}} onClick={()=>goTo('join')}>Get Started</button>
              </div>
            ))}
          </div>
        </div>
      </div>
      <div style={{padding:'72px 28px',textAlign:'center'}}>
        <span style={lbl}>Start Here</span>
        <h2 style={{...DISPLAY,fontSize:48,margin:'10px 0 16px'}}>Free Body Assessment</h2>
        <p style={{color:C.text2,maxWidth:420,margin:'0 auto 28px',fontSize:14,lineHeight:1.7}}>Full body comp scan + coach consult + program recommendation. No commitment required.</p>
        <button style={{...btn(),padding:'14px 32px',fontSize:15}} onClick={()=>goTo('join')}>Book My Assessment</button>
      </div>
    </div>
  );
}

function MembershipsPage({goTo}){
  const plans=[
    {name:'Student Monthly',price:799,per:'month',color:C.purple,includes:['Unlimited gym access','Free body assessment','Coach check-ins 2x/week','Class booking access','Student ID required']},
    {name:'Regular Monthly',price:999,per:'month',color:C.red,featured:true,includes:['Everything in Student','Priority class booking','Monthly progress report','Nutrition guidance','No student ID required']},
    {name:'Annual Regular',price:8000,per:'year',color:C.gold,includes:['Everything in Regular','2x free body comp scans','Annual progress review','Save ₱3,988 vs monthly','Priority coach access']},
    {name:'Annual Student',price:6000,per:'year',color:C.blue,includes:['Everything in Student','2x free body comp scans','Save ₱3,588 vs monthly','Annual review session','Valid student ID required']},
  ];
  return(
    <div style={sec}>
      <span style={lbl}>Pricing</span>
      <h1 style={h1s}>Membership Plans</h1>
      <p style={{color:C.text2,marginBottom:36,fontSize:14}}>All plans include a dedicated coach, free body assessment, and unlimited gym access. No hidden fees.</p>
      <div style={{display:'grid',gridTemplateColumns:'repeat(2,1fr)',gap:18}}>
        {plans.map(p=>(
          <div key={p.name} style={{...card,border:`2px solid ${p.color}`,position:'relative'}}>
            {p.featured&&<div style={{...bdg(C.red),position:'absolute',top:-10,left:20,fontSize:10}}>Most Popular</div>}
            <div style={{fontSize:13,color:C.text2}}>{p.name}</div>
            <div style={{fontSize:36,fontWeight:800,margin:'6px 0'}}>₱{p.price.toLocaleString()}<span style={{fontSize:13,fontWeight:400,color:C.text2}}>/{p.per}</span></div>
            <div style={{borderTop:`1px solid ${C.border}`,paddingTop:14,marginTop:14}}>
              {p.includes.map(i=><div key={i} style={{fontSize:13,color:C.text2,padding:'3px 0',display:'flex',gap:8}}><span style={{color:C.green}}>✓</span>{i}</div>)}
            </div>
            <button style={{...btn(p.featured?C.red:undefined,!p.featured),width:'100%',marginTop:18,fontSize:13}} onClick={()=>goTo('join')}>Get {p.name}</button>
          </div>
        ))}
      </div>
    </div>
  );
}

function CoachingPage({goTo}){
  const [active,setActive]=useState(null);
  return(
    <div style={sec}>
      <span style={lbl}>Our Team</span>
      <h1 style={h1s}>Expert Coaches</h1>
      <p style={{color:C.text2,marginBottom:36,fontSize:14}}>Every member gets an assigned primary coach — your program designer, progress tracker, and accountability partner.</p>
      <div style={{display:'grid',gridTemplateColumns:'repeat(2,1fr)',gap:18}}>
        {COACHES.map(c=>(
          <div key={c.id} style={{...card,cursor:'pointer',border:`1px solid ${active===c.id?c.color:C.border}`}} onClick={()=>setActive(active===c.id?null:c.id)}>
            <div style={{display:'flex',gap:14,marginBottom:14}}>
              <div style={{width:48,height:48,borderRadius:'50%',background:`${c.color}20`,border:`2px solid ${c.color}`,display:'flex',alignItems:'center',justifyContent:'center',fontWeight:700,fontSize:14,color:c.color,flexShrink:0}}>{c.id}</div>
              <div>
                <div style={{fontWeight:700,fontSize:15}}>{c.name}</div>
                <div style={{fontSize:13,color:C.text2}}>{c.title}</div>
                <div style={{fontSize:11,color:C.text3,marginTop:2}}>{c.exp} experience</div>
              </div>
            </div>
            <div style={{display:'flex',gap:24,marginBottom:14}}>
              <div><div style={{fontSize:20,fontWeight:700}}>{c.members}</div><div style={{fontSize:11,color:C.text3}}>Members</div></div>
              <div><div style={{fontSize:20,fontWeight:700,color:C.green}}>{c.retention}%</div><div style={{fontSize:11,color:C.text3}}>Retention</div></div>
              <div><div style={{fontSize:20,fontWeight:700,color:c.color}}>{c.utilization}%</div><div style={{fontSize:11,color:C.text3}}>Utilization</div></div>
            </div>
            <div style={{display:'flex',gap:6,flexWrap:'wrap',marginBottom:active===c.id?14:0}}>
              {c.tags.map(t=><span key={t} style={{fontSize:11,background:C.elev,color:C.text2,padding:'3px 8px',borderRadius:4}}>{t}</span>)}
            </div>
            {active===c.id&&(
              <div>
                <div style={{fontSize:13,color:C.text2,lineHeight:1.7,borderTop:`1px solid ${C.border}`,paddingTop:14,marginBottom:14}}>{c.bio}</div>
                <button style={{...btn(c.color),width:'100%',fontSize:13}} onClick={(e)=>{e.stopPropagation();goTo('join');}}>Train with {c.name.split(' ')[1]}</button>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  );
}

function ClassesPage(){
  const [booked,setBooked]=useState({});
  const [modal,setModal]=useState(null);
  return(
    <div style={sec}>
      <span style={lbl}>Schedule</span>
      <h1 style={h1s}>Class Schedule</h1>
      <p style={{color:C.text2,marginBottom:32,fontSize:14}}>Classes run Mon/Wed/Fri and Tue/Thu/Sat. Book in advance — Evening HIIT fills every week.</p>
      <div style={{display:'flex',flexDirection:'column',gap:10}}>
        {CLASSES.map(cls=>{
          const full=cls.booked>=cls.cap;
          const isBooked=booked[cls.name];
          const pct=Math.round((cls.booked/cls.cap)*100);
          return(
            <div key={cls.name} style={{...card,display:'flex',alignItems:'center',gap:18}}>
              <div style={{minWidth:72,textAlign:'center',background:C.elev,borderRadius:8,padding:'8px 10px'}}>
                <div style={{fontWeight:700,fontSize:14}}>{cls.time}</div>
                <div style={{fontSize:10,color:C.text3}}>{cls.days}</div>
              </div>
              <div style={{flex:1}}>
                <div style={{fontWeight:600,fontSize:14}}>{cls.name}</div>
                <div style={{fontSize:12,color:C.text2}}>{cls.coach}</div>
              </div>
              <div style={{minWidth:110}}>
                <div style={{display:'flex',justifyContent:'space-between',fontSize:11,color:C.text2,marginBottom:4}}>
                  <span>{cls.booked}/{cls.cap}</span>
                  <span style={{color:full?C.red:C.text3}}>{full?'FULL':`${100-pct}% open`}</span>
                </div>
                <div style={{height:3,background:C.elev,borderRadius:2}}>
                  <div style={{height:'100%',background:full?C.red:C.green,borderRadius:2,width:`${Math.min(pct+(isBooked?8:0),100)}%`}}/>
                </div>
              </div>
              <button style={{...btn(isBooked?C.green:full?C.borderBright:C.red),fontSize:12,padding:'7px 14px',minWidth:70}} onClick={()=>{if(!full)setBooked(b=>({...b,[cls.name]:!b[cls.name]}));else setModal(cls.name);}}>
                {isBooked?'Booked':full?'Waitlist':'Book'}
              </button>
            </div>
          );
        })}
      </div>
      {modal&&(
        <div style={{position:'fixed',inset:0,background:'rgba(0,0,0,0.75)',display:'flex',alignItems:'center',justifyContent:'center',zIndex:200}} onClick={()=>setModal(null)}>
          <div style={{...card,maxWidth:360,width:'90%'}} onClick={e=>e.stopPropagation()}>
            <div style={{fontWeight:700,marginBottom:8}}>{modal} — Waitlist</div>
            <div style={{fontSize:13,color:C.text2,marginBottom:16}}>This class is full. Leave your name and we will notify you if a spot opens.</div>
            <input placeholder="Your name" style={{marginBottom:10}}/>
            <input placeholder="Phone number" style={{marginBottom:14}}/>
            <button style={{...btn(),width:'100%',fontSize:13}} onClick={()=>setModal(null)}>Join Waitlist</button>
          </div>
        </div>
      )}
    </div>
  );
}


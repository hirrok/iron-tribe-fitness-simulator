function ContactPage(){
  const [sent,setSent]=useState(false);
  return(
    <div style={sec}>
      <span style={lbl}>Reach Us</span>
      <h1 style={h1s}>Contact</h1>
      <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:28}}>
        <div>
          {[['Visit Us','4F Noli Rose Bldg, 474 J.P. Laurel Highway\nPoblacion, Malvar, Batangas 4233'],
            ['Call or Text','+63 956 700 7785\nAvailable during business hours'],
            ['Business Hours','Monday – Sunday\n8:00 AM – 10:00 PM daily'],
            ['Social Media','Facebook: Iron-Tribe Fitness Gym\nInstagram: @irontribefitnessgym'],
          ].map(([label,value])=>(
            <div key={label} style={{marginBottom:20}}>
              <div style={{fontWeight:600,marginBottom:4,fontSize:13}}>{label}</div>

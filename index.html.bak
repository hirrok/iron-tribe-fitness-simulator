          </div>
        ))}
        <div style={{...card,border:`2px dashed ${C.border}`,display:'flex',alignItems:'center',justifyContent:'center',flexDirection:'column',gap:12,cursor:'pointer',minHeight:180}} onClick={()=>goTo('join')}>
          <div style={{fontWeight:600,fontSize:14}}>Start Your Story</div>
          <div style={{fontSize:12,color:C.text2,textAlign:'center'}}>Book a free assessment and begin your transformation</div>
        </div>
      </div>

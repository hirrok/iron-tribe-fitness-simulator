function JoinPage({goTo}){
  const [step,setStep]=useState(0);
  const [path,setPath]=useState('assessment');
  const [plan,setPlan]=useState('regular');
  const [pay,setPay]=useState('gcash');
  const steps=['Path','Plan','Add-ons','Info','Payment','Confirm'];
  const PLAN_INFO={student:{label:'Student Monthly',price:799},regular:{label:'Regular Monthly',price:999},annual:{label:'Annual Regular',price:8000}};
  const cp=PLAN_INFO[plan]||PLAN_INFO.regular;
  if(step>=6)return(
    <div style={{...sec,textAlign:'center',paddingTop:80}}>
      <div style={{fontSize:52,marginBottom:16}}>🎉</div>
      <h2 style={{...DISPLAY,fontSize:40,marginBottom:12}}>Welcome to Iron Tribe!</h2>
      <p style={{color:C.text2,marginBottom:24,fontSize:14}}>Assessment booked. Your coach will reach out within 24 hours. Check your phone for a confirmation message.</p>
      <button style={btn()} onClick={()=>{setStep(0);goTo('home');}}>Back to Home</button>
    </div>
  );
  const R=({val,current,set,children})=>(
    <div onClick={()=>set(val)} style={{border:`2px solid ${current===val?C.red:C.border}`,borderRadius:8,padding:'12px 14px',marginBottom:10,cursor:'pointer',userSelect:'none'}}>{children}</div>
  );
  return(
    <div style={{maxWidth:560,margin:'0 auto',padding:'52px 28px'}}>
      <span style={lbl}>Join</span>
      <h1 style={{...h1s,marginBottom:28}}>Get Started</h1>
      <div style={{display:'flex',gap:6,marginBottom:32,alignItems:'center'}}>
        {steps.map((st,i)=>(
          <React.Fragment key={st}>
            <div style={{width:26,height:26,borderRadius:'50%',background:i===step?C.red:i<step?C.green:C.elev,display:'flex',alignItems:'center',justifyContent:'center',fontSize:11,fontWeight:700,color:i<=step?'#fff':C.text3,flexShrink:0}}>{i<step?'✓':i+1}</div>
            {i<steps.length-1&&<div style={{flex:1,height:1,background:i<step?C.green:C.border,minWidth:10}}/>}
          </React.Fragment>
        ))}
      </div>
      <div style={{...card,marginBottom:20}}>
        {step===0&&<div>
          <div style={{fontWeight:600,fontSize:15,marginBottom:14}}>How would you like to start?</div>
          <R val="assessment" current={path} set={setPath}><div style={{fontWeight:600,fontSize:14}}>Free Body Assessment</div><div style={{fontSize:12,color:C.text2}}>Full body comp scan + coach consult — no commitment</div></R>
          <R val="monthly" current={path} set={setPath}><div style={{fontWeight:600,fontSize:14}}>Monthly Membership</div><div style={{fontSize:12,color:C.text2}}>Start training immediately with full gym access</div></R>
          <R val="annual" current={path} set={setPath}><div style={{fontWeight:600,fontSize:14}}>Annual Membership</div><div style={{fontSize:12,color:C.text2}}>Best value · Save ₱3,988 · Commit to your year</div></R>
        </div>}
        {step===1&&<div>
          <div style={{fontWeight:600,fontSize:15,marginBottom:14}}>Select your plan</div>
          <R val="student" current={plan} set={setPlan}><div style={{fontWeight:600,fontSize:14}}>Student — ₱799/mo</div><div style={{fontSize:12,color:C.text2}}>Valid student ID required · All base benefits included</div></R>
          <R val="regular" current={plan} set={setPlan}><div style={{fontWeight:600,fontSize:14}}>Regular — ₱999/mo</div><div style={{fontSize:12,color:C.text2}}>Most popular · Priority class booking included</div></R>
          <R val="annual" current={plan} set={setPlan}><div style={{fontWeight:600,fontSize:14}}>Annual — ₱8,000/yr</div><div style={{fontSize:12,color:C.text2}}>Best value · 2x free body comp scans included</div></R>
        </div>}
        {step===2&&<div>
          <div style={{fontWeight:600,fontSize:15,marginBottom:14}}>Optional add-ons</div>
          {['Extra Body Comp Review (+₱200/mo)','Join 30-Day Transformation Challenge (Free)','Photo & Video Consent (for social media)','SMS & Messenger Reminders (Recommended)'].map(item=>(
            <div key={item} style={{border:`1px solid ${C.border}`,borderRadius:8,padding:'12px 14px',marginBottom:8,fontSize:14,color:C.text2}}>{item}</div>
          ))}
        </div>}
        {step===3&&<div>
          <div style={{fontWeight:600,fontSize:15,marginBottom:16}}>Your information</div>
          {[['Full Name','Juan Dela Cruz'],['Phone Number','+63 9XX XXX XXXX'],['Email Address','email@example.com'],['Primary Goal','e.g. Fat loss, muscle building, general fitness']].map(([f,p])=>(
            <div key={f} style={{marginBottom:12}}><div style={{fontSize:12,color:C.text2,marginBottom:6}}>{f}</div><input placeholder={p}/></div>
          ))}
        </div>}
        {step===4&&<div>
          <div style={{fontWeight:600,fontSize:15,marginBottom:14}}>Payment method</div>
          <div style={{display:'grid',gridTemplateColumns:'repeat(2,1fr)',gap:10,marginBottom:18}}>
            {[['gcash','GCash'],['maya','Maya'],['card','Card'],['qr','QR Ph']].map(([v,l])=>(
              <div key={v} onClick={()=>setPay(v)} style={{border:`2px solid ${pay===v?C.red:C.border}`,borderRadius:8,padding:'14px',textAlign:'center',cursor:'pointer',fontSize:14,fontWeight:pay===v?600:400,userSelect:'none'}}>{l}</div>
            ))}
          </div>
          <div style={{background:C.elev,borderRadius:8,padding:'14px 18px'}}>
            <div style={{display:'flex',justifyContent:'space-between',fontSize:13,color:C.text2,marginBottom:6}}><span>{cp.label}</span><span>₱{cp.price.toLocaleString()}</span></div>
            <div style={{display:'flex',justifyContent:'space-between',borderTop:`1px solid ${C.border}`,paddingTop:8,fontWeight:700}}><span>Total</span><span style={{color:C.red}}>₱{cp.price.toLocaleString()}</span></div>
          </div>
        </div>}
        {step===5&&<div>
          <div style={{fontWeight:600,fontSize:15,marginBottom:14}}>Review and confirm</div>
          <div style={{background:C.elev,borderRadius:8,padding:'14px 18px',marginBottom:14}}>
            {[['Plan',`${cp.label} — ₱${cp.price.toLocaleString()}`],['Payment',pay.charAt(0).toUpperCase()+pay.slice(1)],['Assessment','Free body comp scan · Day 1'],['Coach Assignment','Within 24 hours of signup'],['Start Date','Immediate access upon payment']].map(([k,v])=>(
              <div key={k} style={{display:'flex',justifyContent:'space-between',padding:'5px 0',fontSize:13}}><span style={{color:C.text2}}>{k}</span><span>{v}</span></div>
            ))}
          </div>
          <div style={{fontSize:11,color:C.text3}}>By confirming you accept the Membership Waiver and Privacy Policy (Philippines Data Privacy Act of 2012, R.A. 10173).</div>
        </div>}
      </div>
      <div style={{display:'flex',gap:10}}>
        {step>0&&<button style={{...btn(C.red,true),flex:1}} onClick={()=>setStep(n=>n-1)}>Back</button>}
        <button style={{...btn(),flex:2}} onClick={()=>setStep(n=>n+1)}>{step===5?`Confirm and Pay ₱${cp.price.toLocaleString()}`:'Continue'}</button>
      </div>
    </div>
  );
}

function StoriesPage({goTo}){
  return(
    <div style={sec}>
      <span style={lbl}>Community</span>
      <h1 style={h1s}>Success Stories</h1>
      <p style={{color:C.text2,marginBottom:36,fontSize:14}}>Real results from real members. No supplements, no shortcuts — just consistent coaching and hard work.</p>
      <div style={{display:'flex',flexDirection:'column',gap:16}}>
        {REVIEWS.map(r=>(
          <div key={r.name} style={card}>
            <div style={{display:'flex',gap:14,marginBottom:12}}>
              <div style={{width:44,height:44,borderRadius:'50%',background:C.redDim,display:'flex',alignItems:'center',justifyContent:'center',fontWeight:700,color:C.red,fontSize:14,flexShrink:0}}>{r.name.split(' ').map(n=>n[0]).join('')}</div>
              <div>
                <div style={{fontWeight:700,fontSize:14}}>{r.name}</div>
                <div style={{fontSize:12,color:C.text3}}>{r.plan} · {r.date}</div>
                <div style={{fontSize:14,color:C.gold}}>{'★'.repeat(r.rating)}</div>
              </div>
            </div>
            <p style={{fontSize:14,color:C.text2,lineHeight:1.7}}>{r.text}</p>
          </div>
        ))}
      </div>
      <div style={{textAlign:'center',marginTop:40}}>
        <button style={{...btn(),padding:'13px 28px',fontSize:14}} onClick={()=>goTo('join')}>Write Your Own Story</button>
      </div>
      <div style={{...card,marginTop:28,display:'flex',justifyContent:'space-between',alignItems:'center'}}>
        <div><div style={{fontWeight:600,fontSize:14}}>Have a question or ready to visit?</div><div style={{fontSize:13,color:C.text2}}>+63 956 700 7785 · 4F Noli Rose Bldg, Malvar, Batangas</div></div>
        <button style={{...btn(C.red,true),fontSize:13}} onClick={()=>goTo('contact')}>Contact Us</button>
      </div>
    </div>
  );
}

function FAQPage(){
  const [open,setOpen]=useState(0);
  return(
    <div style={sec}>
      <span style={lbl}>Help</span>
      <h1 style={h1s}>Frequently Asked Questions</h1>
      <p style={{color:C.text2,marginBottom:36,fontSize:14}}>Everything you need to know about Iron Tribe membership and training.</p>
      <div style={{display:'flex',flexDirection:'column',gap:8}}>
        {FAQ_ITEMS.map((item,i)=>(
          <div key={i} style={{...card,padding:0,overflow:'hidden'}}>
            <button onClick={()=>setOpen(open===i?-1:i)} style={{width:'100%',background:'transparent',border:'none',padding:'16px 20px',display:'flex',justifyContent:'space-between',alignItems:'center',cursor:'pointer',textAlign:'left'}}>
              <span style={{fontWeight:600,fontSize:14,color:C.text}}>{item.q}</span>
              <span style={{color:C.red,fontSize:20,flexShrink:0,marginLeft:12}}>{open===i?'−':'+'}</span>
            </button>
            {open===i&&<div style={{padding:'0 20px 16px',fontSize:14,color:C.text2,lineHeight:1.7,borderTop:`1px solid ${C.border}`}}><div style={{paddingTop:14}}>{item.a}</div></div>}
          </div>
        ))}
      </div>
    </div>
  );
}

function AdminDashboard(){
  const pct=Math.round((METRICS.mtdRevenue/METRICS.target)*100);
  return(
    <div>
      <div style={{marginBottom:22}}><span style={lbl}>Aurora Operator Suite</span><h2 style={h2s}>Dashboard</h2><div style={{fontSize:12,color:C.text3}}>{new Date().toLocaleDateString('en-PH',{weekday:'long',year:'numeric',month:'long',day:'numeric'})} · Malvar, Batangas</div></div>
      <div style={{display:'grid',gridTemplateColumns:'repeat(4,1fr)',gap:12,marginBottom:20}}>
        {[['MTD Revenue',`₱${METRICS.mtdRevenue.toLocaleString()}`,`${pct}% of target`,C.green],
          ['Active Members',METRICS.active,'5 at risk of churn',C.gold],
          ['New Leads',METRICS.leads,'This week',C.red],
          ['Conversion Rate',`${METRICS.conversionRate}%`,`${METRICS.conversions} converted`,C.text],
        ].map(([label,val,sub,color])=>(
          <div key={label} style={metric}>
            <div style={{fontSize:11,color:C.text3,marginBottom:4}}>{label}</div>
            <div style={{fontSize:22,fontWeight:700,color}}>{val}</div>
            <div style={{fontSize:11,color:C.text3}}>{sub}</div>
          </div>
        ))}
      </div>
      <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:14,marginBottom:14}}>
        <div style={card}>
          <div style={{fontWeight:600,marginBottom:14,fontSize:14}}>June Revenue Progress</div>
          <div style={{display:'flex',justifyContent:'space-between',fontSize:12,color:C.text2,marginBottom:6}}><span>₱{METRICS.mtdRevenue.toLocaleString()} / ₱{METRICS.target.toLocaleString()}</span><span style={{color:C.green}}>{pct}%</span></div>
          <div style={{height:8,background:C.elev,borderRadius:4,marginBottom:8}}><div style={{height:'100%',background:C.green,borderRadius:4,width:`${pct}%`}}/></div>
          <div style={{fontSize:12,color:C.text3}}>Gap: ₱{(METRICS.target-METRICS.mtdRevenue).toLocaleString()} · 21 days remaining</div>
        </div>
        <div style={card}>
          <div style={{fontWeight:600,marginBottom:14,fontSize:14}}>Today's Attendance</div>
          <div style={{display:'flex',justifyContent:'space-between',fontSize:12,color:C.text2,marginBottom:6}}><span>{METRICS.attendanceToday} members in today</span><span style={{color:C.gold}}>{METRICS.attendancePct}% of active</span></div>
          <div style={{height:8,background:C.elev,borderRadius:4,marginBottom:8}}><div style={{height:'100%',background:C.gold,borderRadius:4,width:`${METRICS.attendancePct}%`}}/></div>
          <div style={{fontSize:12,color:C.text3}}>Peak hour: 6:00–8:00 PM</div>
        </div>
      </div>
      <div style={card}>
        <div style={{fontWeight:600,marginBottom:14,fontSize:14}}>At-Risk Members — Needs Attention</div>
        {MEMBERS.filter(m=>m.status==='At Risk').map(m=>(
          <div key={m.name} style={{display:'flex',justifyContent:'space-between',alignItems:'center',padding:'10px 0',borderBottom:`1px solid ${C.border}`,fontSize:13}}>
            <div><div style={{fontWeight:500}}>{m.name}</div><div style={{fontSize:11,color:C.text3}}>{m.coach} · {m.plan} · Last visit: {m.lastVisit}</div></div>
            <div style={{display:'flex',gap:10,alignItems:'center'}}>
              <div style={{textAlign:'right'}}><div style={{color:C.red,fontWeight:700}}>{m.attendance}%</div><div style={{fontSize:10,color:C.text3}}>attendance</div></div>
              <button style={{...btn(C.red),fontSize:11,padding:'5px 10px'}}>Check In</button>
            </div>
          </div>
        ))}
      </div>
    </div>
  );
}

function AdminLeads(){
  const sc={'New Lead':C.text2,'Trial Booked':C.gold,'Assessment Done':C.purple,'Proposal Sent':C.blue,'Converted':C.green,'Lost':C.red};
  return(
    <div>
      <span style={lbl}>CRM</span><h2 style={h2s}>Leads Pipeline</h2>
      <div style={{display:'flex',gap:8,marginBottom:20,flexWrap:'wrap'}}>
        {Object.entries(sc).map(([stage,color])=><span key={stage} style={{...bdg(color),fontSize:10}}>{stage}</span>)}
      </div>
      {LEADS.map(l=>(
        <div key={l.name} style={{...card,display:'flex',alignItems:'center',gap:16,marginBottom:10}}>
          <div style={{width:36,height:36,borderRadius:'50%',background:C.elev,display:'flex',alignItems:'center',justifyContent:'center',fontWeight:700,fontSize:12,flexShrink:0}}>{l.name.split(' ').map(n=>n[0]).join('')}</div>
          <div style={{flex:1}}><div style={{fontWeight:600,fontSize:14}}>{l.name}</div><div style={{fontSize:12,color:C.text2}}>via {l.source} · {l.date} · {l.interest}</div></div>
          <span style={{...bdg(sc[l.stage]||C.text2),fontSize:10}}>{l.stage}</span>
          <button style={{...btn(C.red,true),fontSize:11,padding:'5px 10px'}}>Follow Up</button>
        </div>
      ))}
    </div>
  );
}

function AdminMembers(){
  const [filter,setFilter]=useState('all');
  const filtered=filter==='all'?MEMBERS:MEMBERS.filter(m=>m.status===filter);
  return(
    <div>
      <div style={{display:'flex',justifyContent:'space-between',alignItems:'flex-end',marginBottom:20}}>
        <div><span style={lbl}>CRM</span><h2 style={{...h2s,marginBottom:0}}>Members</h2></div>
        <div style={{display:'flex',gap:8}}>
          {['all','Active','At Risk'].map(f=><button key={f} style={{...btn(C.red,filter!==f),fontSize:12,padding:'6px 12px'}} onClick={()=>setFilter(f)}>{f==='all'?'All':f}</button>)}
        </div>
      </div>
      {filtered.map(m=>(
        <div key={m.name} style={{...card,display:'flex',alignItems:'center',gap:16,marginBottom:10}}>
          <div style={{width:36,height:36,borderRadius:'50%',background:m.status==='At Risk'?`${C.red}20`:`${C.green}20`,display:'flex',alignItems:'center',justifyContent:'center',fontWeight:700,fontSize:12,color:m.status==='At Risk'?C.red:C.green,flexShrink:0}}>{m.name.split(' ').map(n=>n[0]).join('')}</div>
          <div style={{flex:1}}><div style={{fontWeight:600,fontSize:14}}>{m.name}</div><div style={{fontSize:12,color:C.text2}}>{m.coach} · {m.plan} · {m.goal} · Last: {m.lastVisit}</div></div>
          <div style={{textAlign:'right',minWidth:60}}><div style={{fontWeight:700,color:m.attendance<50?C.red:C.text,fontSize:15}}>{m.attendance}%</div><div style={{fontSize:10,color:C.text3}}>attendance</div></div>
          <span style={{...bdg(m.status==='At Risk'?C.red:C.green),fontSize:10,minWidth:54,textAlign:'center'}}>{m.status}</span>
        </div>
      ))}
    </div>
  );
}

function AdminCoaches(){
  return(
    <div>
      <span style={lbl}>Team</span><h2 style={h2s}>Coaches</h2>
      <div style={{display:'grid',gridTemplateColumns:'repeat(2,1fr)',gap:14}}>
        {COACHES.map(c=>(
          <div key={c.id} style={card}>
            <div style={{display:'flex',gap:12,marginBottom:14}}>
              <div style={{width:44,height:44,borderRadius:'50%',background:`${c.color}20`,border:`2px solid ${c.color}`,display:'flex',alignItems:'center',justifyContent:'center',fontWeight:700,fontSize:14,color:c.color,flexShrink:0}}>{c.id}</div>
              <div><div style={{fontWeight:700,fontSize:14}}>{c.name}</div><div style={{fontSize:12,color:C.text2}}>{c.title}</div></div>
            </div>
            <div style={{display:'grid',gridTemplateColumns:'repeat(3,1fr)',gap:10,marginBottom:12}}>
              {[['Members',c.members,C.text],['Retention',`${c.retention}%`,C.green],['Utilization',`${c.utilization}%`,c.color]].map(([l,v,color])=>(
                <div key={l} style={{background:C.elev,borderRadius:6,padding:'8px'}}><div style={{fontSize:16,fontWeight:700,color}}>{v}</div><div style={{fontSize:10,color:C.text3}}>{l}</div></div>
              ))}
            </div>
            <div style={{height:3,background:C.elev,borderRadius:2}}><div style={{height:'100%',background:c.color,borderRadius:2,width:`${c.utilization}%`}}/></div>
          </div>
        ))}
      </div>
    </div>
  );
}

function AdminBookings(){
  return(
    <div>
      <span style={lbl}>Schedule</span><h2 style={h2s}>Class Bookings</h2>
      {CLASSES.map(cls=>{
        const pct=Math.round((cls.booked/cls.cap)*100);
        const full=cls.booked>=cls.cap;
        return(
          <div key={cls.name} style={{...card,display:'flex',alignItems:'center',gap:16,marginBottom:10}}>
            <div style={{minWidth:68,textAlign:'center',background:C.elev,borderRadius:8,padding:'8px 10px'}}><div style={{fontWeight:700,fontSize:13}}>{cls.time}</div><div style={{fontSize:10,color:C.text3}}>{cls.days}</div></div>
            <div style={{flex:1}}><div style={{fontWeight:600,fontSize:14}}>{cls.name}</div><div style={{fontSize:12,color:C.text2}}>{cls.coach}</div></div>
            <div style={{minWidth:100}}>
              <div style={{display:'flex',justifyContent:'space-between',fontSize:11,color:C.text2,marginBottom:4}}><span>{cls.booked}/{cls.cap}</span><span style={{color:full?C.red:C.green}}>{full?'FULL':`${100-pct}% open`}</span></div>
              <div style={{height:3,background:C.elev,borderRadius:2}}><div style={{height:'100%',background:full?C.red:C.green,borderRadius:2,width:`${pct}%`}}/></div>
            </div>
          </div>
        );
      })}
    </div>
  );
}

function AdminChallenges(){
  return(
    <div>
      <span style={lbl}>Engagement</span><h2 style={h2s}>30-Day Challenges</h2>
      {CHALLENGES.map(ch=>(
        <div key={ch.name} style={{...card,marginBottom:14}}>
          <div style={{display:'flex',justifyContent:'space-between',alignItems:'flex-start',marginBottom:14}}>
            <div><div style={{fontWeight:700,fontSize:14}}>{ch.name}</div><div style={{fontSize:12,color:C.text2}}>{ch.start} – {ch.end} · {ch.participants} participants</div></div>
            <span style={{...bdg(ch.status==='Active'?C.green:C.text2),fontSize:10}}>{ch.status}</span>
          </div>
          <div style={{display:'flex',gap:24,padding:'12px 0',borderTop:`1px solid ${C.border}`}}>
            <div><div style={{fontSize:13,color:C.text3}}>Prize</div><div style={{fontSize:13,fontWeight:600}}>{ch.prize}</div></div>
            <div><div style={{fontSize:13,color:C.text3}}>Leader</div><div style={{fontSize:13,fontWeight:600,color:C.gold}}>{ch.leader}</div></div>
            <div><div style={{fontSize:13,color:C.text3}}>Score</div><div style={{fontSize:13,fontWeight:600,color:C.green}}>{ch.score}/100</div></div>
          </div>
        </div>
      ))}
    </div>
  );
}

function AdminReviews(){
  return(
    <div>
      <span style={lbl}>Reputation</span><h2 style={h2s}>Member Reviews</h2>
      <div style={{...metric,marginBottom:20,display:'flex',gap:32}}>
        <div><div style={{fontSize:36,fontWeight:700,color:C.gold}}>4.9</div><div style={{fontSize:12,color:C.text3}}>Avg Rating</div></div>
        <div><div style={{fontSize:36,fontWeight:700}}>{REVIEWS.length}</div><div style={{fontSize:12,color:C.text3}}>Reviews</div></div>
        <div><div style={{fontSize:36,fontWeight:700,color:C.green}}>100%</div><div style={{fontSize:12,color:C.text3}}>Recommend</div></div>
      </div>
      {REVIEWS.map(r=>(
        <div key={r.name} style={{...card,marginBottom:10}}>
          <div style={{display:'flex',justifyContent:'space-between',marginBottom:8}}>
            <div style={{fontWeight:600,fontSize:14}}>{r.name}</div>
            <div style={{display:'flex',alignItems:'center',gap:8}}><span style={{fontSize:13,color:C.gold}}>{'★'.repeat(r.rating)}</span><span style={{fontSize:11,color:C.text3}}>{r.date}</span></div>
          </div>
          <p style={{fontSize:13,color:C.text2,lineHeight:1.6,marginBottom:8}}>{r.text}</p>
          <span style={{...bdg(C.text3),fontSize:10}}>{r.plan}</span>
        </div>
      ))}
    </div>
  );
}

function AdminMarketing(){
  const [active,setActive]=useState(null);
  const {display,running,startTyping}=useTypewriter(8);
  const generate=(type)=>{setActive(type);startTyping(MARKETING_OUTPUTS[type]);};
  return(
    <div>
      <span style={lbl}>Content</span><h2 style={h2s}>Marketing Generator</h2>
      <div style={{display:'grid',gridTemplateColumns:'repeat(2,1fr)',gap:10,marginBottom:20}}>
        {[['facebook','Facebook Post'],['instagram','Instagram Caption'],['campaign','Full Campaign'],['sms','SMS Campaign']].map(([type,label])=>(
          <button key={type} style={{...btn(C.red,active!==type),padding:'12px 16px',fontSize:13,textAlign:'left'}} onClick={()=>generate(type)}>{label}</button>
        ))}
      </div>
      {active&&(
        <div style={{...card,background:'#08080C'}}>
          <div style={{display:'flex',justifyContent:'space-between',marginBottom:10}}>
            <span style={{...bdg(C.red),fontSize:10}}>{active.toUpperCase()}</span>
            <span style={{fontSize:11,color:C.text3}}>{running?'Generating...':'Done'}</span>
          </div>
          <pre style={{fontSize:13,color:C.text2,whiteSpace:'pre-wrap',lineHeight:1.7,fontFamily:'inherit'}}>{display}{running?'|':''}</pre>
        </div>
      )}
    </div>
  );
}

function AdminIntelligence(){
  const pct=Math.round((METRICS.mtdRevenue/METRICS.target)*100);
  return(
    <div>
      <span style={lbl}>Analytics</span><h2 style={h2s}>Business Intelligence</h2>
      <div style={{display:'grid',gridTemplateColumns:'repeat(3,1fr)',gap:12,marginBottom:20}}>
        {[['Revenue MTD',`₱${METRICS.mtdRevenue.toLocaleString()}`,C.green],['Target',`₱${METRICS.target.toLocaleString()}`,C.text2],['Progress',`${pct}%`,C.gold],
          ['Active Members',METRICS.active,C.text],['At-Risk',METRICS.atRisk,C.red],['Conversion',`${METRICS.conversionRate}%`,C.green]].map(([l,v,color])=>(
          <div key={l} style={metric}><div style={{fontSize:11,color:C.text3,marginBottom:4}}>{l}</div><div style={{fontSize:24,fontWeight:700,color}}>{v}</div></div>
        ))}
      </div>
      <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:14}}>
        <div style={card}>
          <div style={{fontWeight:600,marginBottom:14,fontSize:13}}>Revenue by Coach Roster</div>
          {COACHES.map(c=>{
            const rev=c.members*999;
            const maxRev=Math.max(...COACHES.map(x=>x.members*999));
            return(
              <div key={c.id} style={{marginBottom:10}}>
                <div style={{display:'flex',justifyContent:'space-between',fontSize:12,color:C.text2,marginBottom:4}}><span>{c.name.split(' ')[1]}</span><span>₱{rev.toLocaleString()}</span></div>
                <div style={{height:3,background:C.elev,borderRadius:2}}><div style={{height:'100%',background:c.color,borderRadius:2,width:`${Math.round((rev/maxRev)*100)}%`}}/></div>
              </div>
            );
          })}
        </div>
        <div style={card}>
          <div style={{fontWeight:600,marginBottom:14,fontSize:13}}>Plan Distribution</div>
          {[['Regular Monthly',42,C.red],['Annual',28,C.gold],['Student Monthly',30,C.purple]].map(([plan,p,color])=>(
            <div key={plan} style={{marginBottom:10}}>
              <div style={{display:'flex',justifyContent:'space-between',fontSize:12,color:C.text2,marginBottom:4}}><span>{plan}</span><span>{p}%</span></div>
              <div style={{height:3,background:C.elev,borderRadius:2}}><div style={{height:'100%',background:color,borderRadius:2,width:`${p}%`}}/></div>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
}

function AdminAIConsole(){
  const [query,setQuery]=useState(null);
  const {display,running,startTyping}=useTypewriter(10);
  const run=(type)=>{
    setQuery(type);
    setTimeout(()=>startTyping(AI_OUTPUTS[type]),800);
  };
  return(
    <div>
      <span style={lbl}>Intelligence</span><h2 style={h2s}>AI Console</h2>
      <p style={{color:C.text2,fontSize:14,marginBottom:20}}>Run AI-powered analysis on Iron Tribe live data. Select a query to generate insights.</p>
      <div style={{display:'grid',gridTemplateColumns:'repeat(3,1fr)',gap:10,marginBottom:20}}>
        {[['retention','Retention Analysis'],['revenue','Revenue Intelligence'],['leads','Lead Intelligence']].map(([type,label])=>(
          <button key={type} style={{...btn(C.red,query!==type),padding:'12px 16px',fontSize:13}} onClick={()=>run(type)}>{label}</button>
        ))}
      </div>
      {query&&(
        <div style={{...card,background:'#08080C'}}>
          <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:12}}>
            <span style={{...bdg(C.red),fontSize:10}}>AI ANALYSIS</span>
            <span style={{fontSize:11,color:C.text3}}>{running?'Analyzing Iron Tribe data...':'Analysis complete'}</span>
          </div>
          <pre style={{fontSize:13,color:C.text2,whiteSpace:'pre-wrap',lineHeight:1.7,fontFamily:'inherit'}}>{display}{running?'|':''}</pre>
        </div>
      )}
    </div>
  );
}

function AdminSettings(){
  return(
    <div>
      <span style={lbl}>Configuration</span><h2 style={h2s}>Settings</h2>
      <div style={{display:'flex',flexDirection:'column',gap:14}}>
        {[{label:'Gym Information',fields:[['Gym Name','Iron Tribe Fitness Gym'],['Address','4F Noli Rose Bldg, 474 J.P. Laurel Hwy, Malvar, Batangas'],['Phone','+63 956 700 7785'],['Business Hours','8:00 AM – 10:00 PM daily']]},
          {label:'Membership Pricing',fields:[['Student Monthly','799'],['Regular Monthly','999'],['Annual Regular','8000'],['Annual Student','6000']]},
        ].map(group=>(
          <div key={group.label} style={card}>
            <div style={{fontWeight:600,marginBottom:16,fontSize:14}}>{group.label}</div>
            <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:12}}>
              {group.fields.map(([label,val])=>(
                <div key={label}><div style={{fontSize:12,color:C.text2,marginBottom:6}}>{label}</div><input defaultValue={val} style={{fontSize:13}}/></div>
              ))}
            </div>
            <button style={{...btn(),marginTop:14,fontSize:13,padding:'8px 16px'}}>Save Changes</button>
          </div>
        ))}
      </div>
    </div>
  );
}

function AdminPL(){
  const revenue=METRICS.mtdRevenue;
  const exp={Rent:25000,Salaries:35000,Utilities:8000,Supplies:3500,Marketing:5000};
  const totalExp=Object.values(exp).reduce((a,b)=>a+b,0);
  const grossProfit=revenue-totalExp;
  const taxEst=Math.round(grossProfit*0.25);
  const netProfit=grossProfit-taxEst;
  const grossMargin=Math.round((grossProfit/revenue)*100);
  const netMargin=Math.round((netProfit/revenue)*100);
  return(
    <div>
      <span style={lbl}>Financials</span><h2 style={h2s}>{'P&L Overview'}</h2>
      <div style={{fontSize:11,color:C.text3,marginBottom:20}}>Month-to-date · June 2026 · 17 days in</div>
      <div style={{display:'grid',gridTemplateColumns:'repeat(4,1fr)',gap:12,marginBottom:20}}>
        {[['Revenue',`₱${revenue.toLocaleString()}`,C.green],['Total Expenses',`₱${totalExp.toLocaleString()}`,C.red],['Gross Profit',`₱${grossProfit.toLocaleString()}`,C.green],['Net Profit',`₱${netProfit.toLocaleString()}`,C.gold]].map(([l,v,color])=>(
          <div key={l} style={metric}><div style={{fontSize:11,color:C.text3,marginBottom:4}}>{l}</div><div style={{fontSize:20,fontWeight:700,color}}>{v}</div></div>
        ))}
      </div>
      <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:14,marginBottom:20}}>
        <div style={card}>
          <div style={{fontWeight:600,marginBottom:10,fontSize:13}}>Gross Margin</div>
          <div style={{fontSize:36,fontWeight:800,color:C.green,marginBottom:8}}>{grossMargin}%</div>
          <div style={{height:6,background:C.elev,borderRadius:3}}><div style={{height:'100%',background:C.green,borderRadius:3,width:`${grossMargin}%`}}/></div>
          <div style={{fontSize:11,color:C.text3,marginTop:8}}>Revenue minus operating expenses</div>
        </div>
        <div style={card}>
          <div style={{fontWeight:600,marginBottom:10,fontSize:13}}>Net Margin (after 25% tax est.)</div>
          <div style={{fontSize:36,fontWeight:800,color:C.gold,marginBottom:8}}>{netMargin}%</div>
          <div style={{height:6,background:C.elev,borderRadius:3}}><div style={{height:'100%',background:C.gold,borderRadius:3,width:`${netMargin}%`}}/></div>
          <div style={{fontSize:11,color:C.text3,marginTop:8}}>Net: ₱{netProfit.toLocaleString()} after ₱{taxEst.toLocaleString()} estimated tax</div>
        </div>
      </div>
      <div style={card}>
        <div style={{fontWeight:600,marginBottom:16,fontSize:13}}>Expense Breakdown</div>
        {Object.entries(exp).map(([key,val])=>{
          const pct=Math.round((val/totalExp)*100);
          return(
            <div key={key} style={{marginBottom:12}}>
              <div style={{display:'flex',justifyContent:'space-between',fontSize:12,color:C.text2,marginBottom:4}}><span>{key}</span><span>₱{val.toLocaleString()} ({pct}%)</span></div>
              <div style={{height:3,background:C.elev,borderRadius:2}}><div style={{height:'100%',background:C.text3,borderRadius:2,width:`${pct}%`}}/></div>
            </div>
          );
        })}
        <div style={{borderTop:`1px solid ${C.border}`,paddingTop:12,marginTop:4,display:'flex',justifyContent:'space-between',fontSize:13,fontWeight:700}}>
          <span>Total</span><span style={{color:C.red}}>₱{totalExp.toLocaleString()}</span>
        </div>
      </div>
    </div>
  );
}

function AdminSuite(){
  const [unlocked,setUnlocked]=useState(false);
  const [pin,setPin]=useState('');
  const [panel,setPanel]=useState('dashboard');
  if(!unlocked)return(
    <div style={{display:'flex',alignItems:'center',justifyContent:'center',height:'calc(100vh - 56px)',background:C.bg}}>
      <div style={{...card,maxWidth:320,width:'90%',textAlign:'center',padding:'36px 28px'}}>
        <div style={{...DISPLAY,fontSize:26,color:C.red,marginBottom:4}}>OPERATOR SUITE</div>
        <div style={{fontSize:11,color:C.text3,letterSpacing:'0.1em',textTransform:'uppercase',marginBottom:24}}>Iron Tribe · Restricted Access</div>
        <input type="password" placeholder="Enter operator code" value={pin} onChange={e=>setPin(e.target.value)} onKeyDown={e=>{if(e.key==='Enter'){if(pin==='irontribe2026')setUnlocked(true);else setPin('');}}} style={{marginBottom:12,textAlign:'center',letterSpacing:'0.2em'}}/>
        <button style={{...btn(),width:'100%',fontSize:13}} onClick={()=>{if(pin==='irontribe2026')setUnlocked(true);else setPin('');}}>Enter</button>
        <div style={{fontSize:11,color:C.text3,marginTop:16}}>Authorized personnel only</div>
      </div>
      </div>
  );
  const nav=[['dashboard','Dashboard'],['pl','P&L'],['leads','Leads'],['members','Members'],['coaches','Coaches'],['bookings','Bookings'],['challenges','Challenges'],['reviews','Reviews'],['marketing','Marketing'],['intelligence','Intelligence'],['ai','AI Console'],['settings','Settings']];
  const panels={dashboard:AdminDashboard,pl:AdminPL,leads:AdminLeads,members:AdminMembers,coaches:AdminCoaches,bookings:AdminBookings,challenges:AdminChallenges,reviews:AdminReviews,marketing:AdminMarketing,intelligence:AdminIntelligence,ai:AdminAIConsole,settings:AdminSettings};
  const Panel=panels[panel]||AdminDashboard;
  return(
    <div style={{display:'flex',height:'calc(100vh - 56px)'}}>
      <div style={{width:200,background:'#050507',borderRight:`1px solid ${C.border}`,padding:'16px 10px',flexShrink:0,overflowY:'auto'}}>
        {nav.map(([k,l])=>(
          <div key={k} onClick={()=>setPanel(k)} style={{padding:'9px 12px',borderRadius:8,marginBottom:3,cursor:'pointer',fontSize:13,background:panel===k?C.redDim:'transparent',color:panel===k?C.red:C.text2,fontWeight:panel===k?600:400,userSelect:'none'}}>{l}</div>
        ))}
      </div>
      <div style={{flex:1,overflowY:'auto',padding:'28px 32px'}}><Panel/></div>
    </div>
  );
}

function Footer({goTo}){
  return(
    <footer style={{background:'#050507',borderTop:`1px solid ${C.border}`,padding:'36px 28px 24px'}}>
      <div style={{maxWidth:1100,margin:'0 auto',display:'grid',gridTemplateColumns:'1.5fr 1fr 1fr',gap:32,marginBottom:24}}>
        <div>
          <div style={{...DISPLAY,color:C.red,fontSize:20,marginBottom:10}}>IRON TRIBE FITNESS GYM</div>
          <div style={{fontSize:13,color:C.text3,lineHeight:1.8}}>4F Noli Rose Bldg, 474 J.P. Laurel Hwy<br/>Poblacion, Malvar, Batangas 4233<br/>+63 956 700 7785<br/>Open 8:00 AM – 10:00 PM daily</div>
        </div>
        <div>
          <div style={{fontSize:11,fontWeight:700,color:C.text2,marginBottom:12,textTransform:'uppercase',letterSpacing:'0.08em'}}>Pages</div>
          {[['home','Home'],['memberships','Memberships'],['coaching','Coaching'],['classes','Classes'],['transformations','Results'],['about','About'],['contact','Contact'],['faq','FAQ']].map(([p,l])=>(
            <div key={p} onClick={()=>goTo(p)} style={{fontSize:13,color:C.text3,marginBottom:7,cursor:'pointer'}}>{l}</div>
          ))}
        </div>
        <div>
          <div style={{fontSize:11,fontWeight:700,color:C.text2,marginBottom:12,textTransform:'uppercase',letterSpacing:'0.08em'}}>Get Started</div>
          <div style={{fontSize:13,color:C.text3,lineHeight:1.8,marginBottom:16}}>Free body assessment — no commitment required. We'll match you with the right coach and program from day one.</div>
          <button style={{...btn(),fontSize:13,padding:'10px 18px'}} onClick={()=>goTo('join')}>Book Free Assessment</button>
        </div>
      </div>
      <div style={{maxWidth:1100,margin:'0 auto',paddingTop:16,borderTop:`1px solid ${C.border}`,display:'flex',justifyContent:'space-between',fontSize:11,color:C.text3}}>
        <span>© 2026 Iron Tribe Fitness Gym · Malvar, Batangas</span>
        <span>Powered by <span style={{color:C.red}}>Aurora Digital Foundry</span></span>
      </div>
    </footer>
  );
}

function App(){
  const [page,setPage]=useState('home');
  const [adminMode,setAdminMode]=useState(false);
  const goTo=(p)=>{setPage(p);window.scrollTo(0,0);};
  const pages={
    home:<HomePage goTo={goTo}/>,
    memberships:<MembershipsPage goTo={goTo}/>,
    coaching:<CoachingPage goTo={goTo}/>,
    classes:<ClassesPage/>,
    transformations:<TransformationsPage goTo={goTo}/>,
    about:<AboutPage goTo={goTo}/>,
    contact:<ContactPage/>,
    join:<JoinPage goTo={goTo}/>,
    stories:<StoriesPage goTo={goTo}/>,
    faq:<FAQPage/>,
  };
  return(
    <div style={{background:C.bg,minHeight:'100vh',color:C.text,display:'flex',flexDirection:'column'}}>
      <NavBar page={page} goTo={goTo} adminMode={adminMode} setAdminMode={setAdminMode}/>
      <div style={{flex:1}}>{adminMode?<AdminSuite/>:(pages[page]||pages.home)}</div>
      {!adminMode&&<Footer goTo={goTo}/>}
    </div>
  );
}

ReactDOM.createRoot(document.getElementById('root')).render(<App/>);
</script>
</body>
</html>

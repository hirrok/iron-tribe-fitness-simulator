<style>
*{box-sizing:border-box;margin:0;padding:0}
html,body{background:#070709;color:#F0F0F5;font-family:'Inter',system-ui,sans-serif;min-height:100%}
input,textarea,select{background:#14141A;border:1px solid #1E1E28;border-radius:8px;padding:10px 14px;color:#F0F0F5;font-size:14px;width:100%;outline:none;font-family:'Inter',system-ui,sans-serif}
input:focus,textarea:focus{border-color:#EF4444}
textarea{resize:vertical;min-height:100px}
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:#070709}
::-webkit-scrollbar-thumb{background:#1E1E28;border-radius:2px}
</style>
</head>

        {transforms.map(t=>(
          <div key={t.name} style={card}>
            <div style={{width:52,height:52,borderRadius:'50%',background:C.redDim,border:`1px solid ${C.red}`,display:'flex',alignItems:'center',justifyContent:'center',fontWeight:700,color:C.red,fontSize:14,marginBottom:14}}>{t.name.split(' ').map(n=>n[0]).join('')}</div>

            </div>
          ):(
            <div>
              <div style={{fontWeight:600,marginBottom:16}}>Send a Message</div>
              {[['Full Name','Juan Dela Cruz'],['Phone Number','+63 9XX XXX XXXX'],['Email Address','email@example.com']].map(([f,p])=>(
                <div key={f} style={{marginBottom:12}}><div style={{fontSize:12,color:C.text2,marginBottom:6}}>{f}</div><input placeholder={p}/></div>
              ))}

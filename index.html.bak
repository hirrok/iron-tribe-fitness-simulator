const FAQ_ITEMS=[
  {q:'What is included in the free body assessment?',a:'Full body composition scan (weight, BMI, muscle mass, body fat %), a 15-minute consultation with your assigned coach, a recommended program based on your goals, and a plan recommendation. No commitment required.'},
  {q:'How much does membership cost?',a:'Student Monthly: ₱799/month (valid student ID required). Regular Monthly: ₱999/month. Annual Regular: ₱8,000/year. Annual Student: ₱6,000/year. All plans include unlimited gym access, free body assessment, and twice-weekly coach check-ins.'},
  {q:'What are your business hours?',a:"We're open Monday through Sunday, 8:00 AM to 10:00 PM daily. Holiday hours may vary — we'll post any changes on our Facebook and Instagram pages."},
  {q:'Can I freeze my membership?',a:'Yes. All plans allow you to freeze your membership up to 2 times per year, for a maximum of 1 month per freeze. Just notify us before your freeze period starts.'},
  {q:'Do I need to book classes in advance?',a:"We recommend booking in advance for popular classes, especially Coach Rica's Evening HIIT sessions, which regularly fill up. Regular and Annual members get priority booking."},
  {q:'Will I be assigned a personal coach?',a:'Yes. Every member is assigned a primary coach based on your goals and schedule at the time of assessment. Your coach conducts check-ins twice a week, reviews your progress, and adjusts your program as needed.'},
  {q:'What payment methods do you accept?',a:"We accept GCash, Maya, credit/debit card, and QR Ph. Cash is also accepted at the gym. Online checkout uses PayMongo's secure payment gateway."},
  {q:"I'm a complete beginner. Is Iron Tribe for me?",a:'Absolutely. Iron Tribe was built for students and adults of all fitness levels. Your coach will design a program that starts where you are — not where someone else is.'},
];

